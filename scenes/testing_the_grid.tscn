[sub_resource type="GDScript" id="GDScript_fobxg"]
script/source = "extends Node2D

@export var events_bus:CellEventsBus

func _ready() -> void:
  events_bus.mouse_entered.connect( func( cell ): cell.show_outline() )
  events_bus.mouse_exited.connect( func( cell ): cell.hide_outline() )
  
  $GridManager.setup( $TileMapLayer )
"

